# ─────────────── App Configuration ───────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ───────────── Authentication (Google) ─────────────
# Get these from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_id_here
GOOGLE_CLIENT_SECRET=your_google_secret_here

# ────────────── Database (PostgreSQL) ──────────────
# Used by docker-compose and Prisma
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=openpass

# Connection string for Prisma (and other services)
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@localhost:5432/${DB_NAME}?schema=public

# ────────────── CI/CD & Build Flags ──────────────
# Set to '1' during build/CI to skip secret validation
SKIP_ENV_VALIDATION=

# ────────────── EMAIL PROVIDER (RESEND) ──────────────
RESEND_API_KEY=resend_api_key_here
EMAIL_FROM=email_from 
